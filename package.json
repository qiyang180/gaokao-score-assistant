{
  "name": "gaokao-score-agent",
  "version": "0.1.0",
  "description": "Windows 本地高考成绩半自动查询与汇总工具",
  "author": "yangqi",
  "private": true,
  "main": "app/main.cjs",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepare:students": "node tools/normalize_students.mjs --input data/students.xlsx --out work/students.csv",
    "demo": "powershell -ExecutionPolicy Bypass -File tools/run_demo.ps1",
    "test:controls": "node tools/test_controls.mjs",
    "test:packaged": "node tools/test_packaged.mjs",
    "query": "node src/query_scores.mjs",
    "summary": "node tools/build_summary.mjs --results output/results.jsonl --out output/score_summary.xlsx",
    "night": "powershell -ExecutionPolicy Bypass -File tools/run_query.ps1",
    "install:browsers": "node tools/install_browsers.mjs",
    "test": "npm run test:controls && npm run test:license",
    "license:keygen": "node tools/generate_license_keys.mjs",
    "license:server": "npm --prefix license-server start",
    "test:license": "node --test test/license_protocol.test.mjs test/license_manager.test.mjs license-server/test/license_service.test.mjs license-server/test/app.test.mjs",
    "app:dev": "node app/dev.mjs",
    "app:vite": "vite --config app/renderer/vite.config.mjs",
    "app:build": "vite build --config app/renderer/vite.config.mjs && node tools/write_license_config.mjs",
    "app:start": "electron .",
    "dist:win": "npm run app:build && npm run install:browsers && electron-builder --win --x64",
    "dist:win:signed": "npm run app:build && npm run install:browsers && electron-builder --win --x64 --config.win.signAndEditExecutable=true"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "playwright": "^1.54.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "local.gaokao.score.agent",
    "productName": "高考成绩查询助手",
    "directories": {
      "output": "dist-electron"
    },
    "extraResources": [
      {
        "from": "vendor/playwright-browsers",
        "to": "playwright-browsers",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "app/main.cjs",
      "app/preload.cjs",
      "app/licensing/**/*",
      "shared/**/*",
      "dist/renderer/**/*",
      "dist/license-config.json",
      "src/**/*",
      "tools/**/*",
      "!tools/**/*.py",
      "!tools/**/__pycache__/**",
      "!tools/install_browsers.mjs",
      "!tools/generate_license_keys.mjs",
      "!tools/write_license_config.mjs",
      "!tools/lib/test_license.mjs",
      "!tools/test_*.mjs",
      "!tools/*.ps1",
      "config.example.json",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asar": true
  }
}
